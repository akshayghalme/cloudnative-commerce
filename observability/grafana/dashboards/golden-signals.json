{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "The Four Golden Signals (Google SRE) for commerce services: Latency, Traffic, Errors, Saturation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🔴 Request Rate (Traffic)",
      "description": "HTTP requests per second by service — the primary indicator of load.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"commerce\"}[5m])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "title": "🔴 Error Rate (Errors)",
      "description": "Percentage of 5xx responses — the most critical signal. Alert if > 1%.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"commerce\", status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total{namespace=\"commerce\"}[5m])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "title": "🟡 P50 / P95 / P99 Latency",
      "description": "Request latency percentiles — P99 matters most for user experience.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"commerce\"}[5m])) by (le, service))",
          "legendFormat": "{{ service }} P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"commerce\"}[5m])) by (le, service))",
          "legendFormat": "{{ service }} P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"commerce\"}[5m])) by (le, service))",
          "legendFormat": "{{ service }} P99"
        }
      ]
    },
    {
      "title": "🟡 CPU Saturation",
      "description": "CPU usage vs requests — when this approaches limits, latency degrades.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"commerce\", container!=\"\"}[5m])) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"commerce\", resource=\"cpu\"}) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "🟡 Memory Saturation",
      "description": "Memory usage vs limits — OOM kills happen when this hits 100%.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"commerce\", container!=\"\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=\"commerce\", resource=\"memory\"}) by (pod)",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
      "title": "HTTP Status Code Breakdown",
      "description": "Response codes over time — spot patterns in 4xx/5xx errors.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"commerce\"}[5m])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["commerce", "golden-signals", "sre"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total{namespace=\"commerce\"}, service)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Commerce — Golden Signals",
  "uid": "commerce-golden-signals",
  "version": 1
}
