%%{init: {'theme': 'default', 'themeVariables': { 'fontSize': '14px', 'primaryColor': '#e3f2fd', 'primaryBorderColor': '#1565c0', 'primaryTextColor': '#1a1a1a', 'lineColor': '#1565c0', 'secondaryColor': '#fff3e0', 'tertiaryColor': '#e8f5e9' }}}%%

graph TB
    USER(["👤 Users — HTTPS"])
    DEV(["👨‍💻 Developer — git push"])

    subgraph GH["<b>GitHub Actions — CI/CD</b>"]
        CI["<b>CI Pipeline</b><br/>Lint → Test → Build → Push"]
        SCAN["<b>Security Scan</b><br/>Trivy · Checkov · Semgrep"]
        SIGN["<b>Sign + SBOM</b><br/>Cosign · Syft"]
    end

    subgraph AWS["<b>AWS — VPC 10.0.0.0/16 — ap-south-1 — 3 AZs</b>"]
        NLB["<b>NLB</b><br/>Network Load Balancer"]

        subgraph EKS["<b>EKS Cluster</b>"]
            INGRESS["<b>ingress-nginx</b><br/>TLS Termination"]

            subgraph GITOPS["<b>Platform — GitOps + Security</b>"]
                ARGO["<b>ArgoCD</b><br/>ApplicationSet · 9 Apps"]
                KYVERNO["<b>Kyverno</b><br/>Image Signatures + 5 Policies"]
                KARPENTER["<b>Karpenter</b><br/>Spot + On-Demand Nodes"]
                CERTMGR["<b>cert-manager</b><br/>Let's Encrypt TLS"]
                EXTSEC["<b>External Secrets</b><br/>AWS SM → K8s Secrets"]
            end

            subgraph SERVICES["<b>Commerce Services</b>"]
                API["<b>product-api</b><br/>Go · REST · :8080"]
                WEB["<b>storefront</b><br/>Next.js · SSR · :3000"]
                WORKER["<b>order-worker</b><br/>Python · SQS Consumer"]
            end

            subgraph MON["<b>Observability — Metrics · Logs · Traces</b>"]
                PROM["<b>Prometheus</b><br/>Metrics · SLO Rules · 15d"]
                GRAFANA["<b>Grafana</b><br/>Golden Signals · Cluster · Cost"]
                LOKI["<b>Loki + Promtail</b><br/>Log Aggregation · 14d"]
                OTEL["<b>OTel → Tempo</b><br/>Distributed Traces · 7d"]
                AM["<b>Alertmanager</b><br/>Burn-Rate Alerts"]
            end
        end

        subgraph DATA["<b>Data Layer — Private Subnets</b>"]
            RDS[("<b>RDS PostgreSQL</b><br/>db.t4g.micro")]
            REDIS[("<b>ElastiCache Redis</b><br/>cache.t4g.micro")]
        end

        ECR["<b>ECR</b><br/>3 Image Repos"]
        SQS["<b>SQS</b><br/>Order Queue"]
        SM["<b>Secrets Manager</b>"]
        S3["<b>S3</b><br/>Terraform State"]
    end

    NOTIFY(["🔔 Slack + PagerDuty"])

    %% User traffic
    USER --> NLB --> INGRESS
    INGRESS --> API
    INGRESS --> WEB
    WEB -.->|SSR API calls| API

    %% CI/CD
    DEV --> GH
    CI -->|Push image| ECR
    SIGN -->|Signed image| ECR

    %% GitOps
    ARGO -->|Sync from Git| SERVICES
    KYVERNO -.->|Verify sigs| ECR

    %% Data flow
    API --> RDS
    API --> REDIS
    API -->|Publish orders| SQS
    WORKER -->|Poll orders| SQS
    WORKER --> RDS

    %% Platform
    EXTSEC -.-> SM
    CERTMGR -.-> INGRESS

    %% Observability
    SERVICES -.->|Metrics + Traces| OTEL
    OTEL --> PROM
    PROM --> GRAFANA
    LOKI --> GRAFANA
    OTEL -.-> GRAFANA
    PROM --> AM --> NOTIFY

    %% Terraform
    GH -.->|Terraform Plan/Apply| S3

    %% Styles
    style AWS fill:#f5f5f5,stroke:#ff9800,stroke-width:2px,color:#1a1a1a
    style EKS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#1a1a1a
    style GITOPS fill:#e8eaf6,stroke:#3949ab,stroke-width:1px,color:#1a1a1a
    style SERVICES fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px,color:#1a1a1a
    style MON fill:#fff3e0,stroke:#e65100,stroke-width:1px,color:#1a1a1a
    style DATA fill:#fce4ec,stroke:#c62828,stroke-width:1px,color:#1a1a1a
    style GH fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#1a1a1a
