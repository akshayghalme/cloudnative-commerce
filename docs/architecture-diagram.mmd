%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '18px', 'fontFamily': 'arial', 'primaryColor': '#dbeafe', 'primaryBorderColor': '#2563eb', 'primaryTextColor': '#111', 'lineColor': '#475569' }, 'flowchart': { 'nodeSpacing': 40, 'rankSpacing': 60, 'curve': 'basis', 'padding': 20 }}}%%

graph TB
    U(["👤 Users — HTTPS"]) --> NLB
    D(["👨‍💻 Developer — git push"]) --> GH

    subgraph CICD["<b>CI/CD — GitHub Actions</b>"]
        GH["GitHub Actions"] --> LINT["Lint · Test · Build"]
        LINT --> SCAN["Trivy · Checkov · Semgrep"]
        SCAN --> SIGN["Cosign Sign · Syft SBOM"]
        SIGN -->|push signed image| ECR["ECR Registry"]
    end

    subgraph CLOUD["<b>AWS — ap-south-1 — VPC 10.0.0.0/16 — 3 AZs</b>"]
        NLB["NLB"] --> NGINX["ingress-nginx + TLS"]

        subgraph EKS["<b>EKS Cluster</b>"]
            NGINX --> API["<b>product-api</b><br/>Go · REST · :8080"]
            NGINX --> WEB["<b>storefront</b><br/>Next.js · SSR · :3000"]
            WEB -.->|API calls| API

            WORKER["<b>order-worker</b><br/>Python · SQS Consumer"]

            subgraph PLAT["<b>Platform</b>"]
                ARGO["ArgoCD — 9 Apps"]
                KYVERNO["Kyverno — 5 Policies"]
                KARPENTER["Karpenter — Spot + OD"]
                CERTMGR["cert-manager"]
                EXTSEC["External Secrets"]
            end

            subgraph OBSV["<b>Observability</b>"]
                PROM["Prometheus — Metrics · SLOs"]
                GRAFANA["Grafana — 3 Dashboards"]
                LOKI["Loki — Logs · 14d"]
                TEMPO["OTel → Tempo — Traces · 7d"]
                ALERTMGR["Alertmanager — Burn-Rate"]
            end
        end

        subgraph DATASTORE["<b>Data — Private Subnets</b>"]
            RDS[("PostgreSQL — RDS")]
            REDIS[("Redis — ElastiCache")]
            SQS["SQS — Order Queue"]
        end

        SM["Secrets Manager"]
        S3["S3 — TF State"]
    end

    NOTIFY(["🔔 Slack + PagerDuty"])

    %% Data flow
    API --> RDS
    API --> REDIS
    API -->|publish| SQS
    WORKER -->|poll| SQS
    WORKER --> RDS

    %% GitOps
    ARGO -->|sync| API
    ARGO -->|sync| WEB
    ARGO -->|sync| WORKER
    KYVERNO -.->|verify sigs| ECR
    EXTSEC -.-> SM

    %% Observability
    API -.-> PROM
    WEB -.-> PROM
    WORKER -.-> PROM
    API -.-> TEMPO
    PROM --> GRAFANA
    LOKI --> GRAFANA
    TEMPO --> GRAFANA
    PROM --> ALERTMGR --> NOTIFY

    %% Terraform
    GH -.->|terraform| S3

