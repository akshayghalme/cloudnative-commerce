# Copy this file to .env and fill in values before running docker-compose
# Never commit .env — it is in .gitignore

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=commerce
POSTGRES_USER=commerce
POSTGRES_PASSWORD=changeme

# ── Product API ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://commerce:changeme@postgres:5432/commerce
REDIS_ADDR=redis:6379
REDIS_PASS=
PORT=8080
ENV=development

# ── Storefront ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Order Worker ──────────────────────────────────────────────────────────────
# For local dev, ElasticMQ (SQS-compatible) runs as a sidecar
SQS_QUEUE_URL=http://elasticmq:9324/000000000000/orders
AWS_REGION=ap-south-1
BATCH_SIZE=10
WAIT_TIME_SECONDS=5
VISIBILITY_TIMEOUT=60

# ── AWS (only needed if testing against real SQS) ─────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
